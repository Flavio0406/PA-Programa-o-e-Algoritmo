programa
{
	
	funcao inicio()
	{
		escreva("seu nome é: "+ mostrar())
	}
	funcao cadeia mostrar(){
			cadeia nome 
			escreva ("digite seu nome: ")
			leia(nome)

		 retorne nome
		 
	}
	
}
